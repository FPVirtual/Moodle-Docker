# =============================================================================
# new-moodle - Variables de entorno
# =============================================================================
# Configuración para sustituir www.fpvirtualaragon.es conectado a
# MariaDB 10.11.16 externo (moodle_mariadb_10.11.16, red mariadb_10.11.16_network)
# ---------------------------------------------------------------------------

# =============================================================================
# Base de datos (externa - MariaDB 10.11.16)
# =============================================================================

MOODLE_DB_HOST=moodle_mariadb_10.11.13
MOODLE_DB_PORT=3306
MOODLE_DB_NAME=moodle
MOODLE_DB_USER=moodle
MOODLE_DB_PASSWORD=moodle_password

# Solo necesario si usas el perfil "with-db" (DB interna en el stack)
# En este despliegue NO se usa el perfil with-db.
MYSQL_ROOT_PASSWORD=root_password

# =============================================================================
# Moodle
# =============================================================================

MOODLE_URL=https://redestel.fpvirtualaragon.es
VIRTUAL_HOST=redestel.fpvirtualaragon.es
MOODLE_LANG=es
MOODLE_SITE_NAME="FP virtual - Aragón"
MOODLE_SITE_FULLNAME="FP virtual - Aragón"

MOODLE_ADMIN_USER=admin
MOODLE_ADMIN_PASSWORD=AeducAR#2020
MOODLE_ADMIN_EMAIL=pruizs@campusdigitalfp.com

# =============================================================================
# Código Moodle externo (opcional)
# =============================================================================
# Si usas docker-compose.override.yml para montar código externo, esta variable
# indica la ruta al código Moodle en el host.
# Ejemplos:
#   MOODLE_CODE_PATH=./moodle-code          # path relativo al proyecto
#   MOODLE_CODE_PATH=/opt/moodle            # path absoluto del servidor
#   MOODLE_CODE_PATH=/home/usuario/moodle   # otro path externo
#
# Si no usas docker-compose.override.yml, se usa el código empaquetado
# dentro de la imagen Docker.
# MOODLE_CODE_PATH=./moodle-code

# =============================================================================
# Proxy / SSL
# =============================================================================

SSL_PROXY=true
SSL_EMAIL=juandacorreo@gmail.com

# =============================================================================
# SMTP
# =============================================================================

SMTP_HOSTS=smtp.aragon.es:587
SMTP_USER=catedu_noreply@educa.aragon.es
SMTP_PASSWORD=NY0H9sUi5ICx9zfn-ma97j_a
SMTP_MAXBULK=100
NO_REPLY_ADDRESS=catedu_noreply@educa.aragon.es

