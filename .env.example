# =============================================================================
# new-moodle - Variables de entorno
# =============================================================================
# Copia este archivo a .env y personaliza los valores
# ---------------------------------------------------------------------------

# =============================================================================
# Base de datos
# =============================================================================

# Host de la base de datos.
# - Si usas la DB interna (perfil with-db): dejar como "db"
# - Si usas una DB externa (otro contenedor o servidor): indicar IP o hostname
MOODLE_DB_HOST=db
MOODLE_DB_PORT=3306
MOODLE_DB_NAME=moodle
MOODLE_DB_USER=moodle
MOODLE_DB_PASSWORD=cambiar_esta_contraseña

# Solo necesario si usas el perfil "with-db" (DB interna en el stack)
MYSQL_ROOT_PASSWORD=root_password_segura

# =============================================================================
# Moodle
# =============================================================================

MOODLE_URL=https://fpd.catedu.es
VIRTUAL_HOST=fpd.catedu.es
MOODLE_LANG=es
MOODLE_SITE_NAME="FP Virtual Aragón"
MOODLE_SITE_FULLNAME="Formación Profesional Virtual a Distancia de Aragón"

MOODLE_ADMIN_USER=admin
MOODLE_ADMIN_PASSWORD=cambiar_esta_contraseña
MOODLE_ADMIN_EMAIL=admin@catedu.es

# =============================================================================
# Código Moodle externo (opcional)
# =============================================================================
# Si usas docker-compose.override.yml para montar código externo, esta variable
# indica la ruta al código Moodle en el host.
# Ejemplos:
#   MOODLE_CODE_PATH=./moodle-code          # path relativo al proyecto
#   MOODLE_CODE_PATH=/opt/moodle            # path absoluto del servidor
#   MOODLE_CODE_PATH=/home/usuario/moodle   # otro path externo
#
# Si no usas docker-compose.override.yml, se usa el código empaquetado
# dentro de la imagen Docker.
# MOODLE_CODE_PATH=./moodle-code

# =============================================================================
# Proxy / SSL
# =============================================================================

SSL_PROXY=true
SSL_EMAIL=admin@catedu.es

# =============================================================================
# SMTP
# =============================================================================

SMTP_HOSTS=smtp.catedu.es
SMTP_USER=
SMTP_PASSWORD=
SMTP_MAXBULK=1
NO_REPLY_ADDRESS=noreply@catedu.es

# =============================================================================
# Otros
# =============================================================================

CRON_BROWSER_PASS=
INSTALL_TYPE=new-install
VERSION=4.1.19

# Contraseñas específicas del entorno FPD
FPD_PASSWORD=
FPD_EMAIL=
MANAGER_PASSWORD=
APP_PASSWORD=
APP_TEACHER_PASSWORD=

# Integración Blackboard
BLACKBOARD_URL=
BLACKBOARD_KEY=
BLACKBOARD_SECRET=
